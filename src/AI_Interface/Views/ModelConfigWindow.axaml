<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AI_Interface.ViewModels"
        xmlns:models="using:AI_Interface.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="660"
        x:Class="AI_Interface.Views.ModelConfigWindow"
        x:DataType="vm:ModelConfigViewModel"
        Width="760" Height="670"
        MinWidth="660" MinHeight="540"
        WindowStartupLocation="CenterOwner"
        Title="LLM Browser">

    <Design.DataContext>
        <vm:ModelConfigViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style Selector="TextBlock.colhead">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <!-- Compact action buttons inside a row -->
        <Style Selector="Button.rowaction">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
        <!-- Make list rows blend into the card -->
        <Style Selector="ListBox.models">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="ListBox.models ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
    </Window.Styles>

    <Border Classes="card" CornerRadius="4" Margin="14" Padding="18">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" RowSpacing="10">

            <!-- Header -->
            <StackPanel Grid.Row="0">
                <TextBlock Classes="brand" Text="LLM Browser"/>
                <TextBlock Classes="muted" TextWrapping="Wrap"
                           Text="Scan your machine, then pick what you need — the list ranks Ollama models from the best match for your hardware to the worst. Select a model to download or remove it."/>
            </StackPanel>

            <!-- Scan + hardware summary -->
            <Border Grid.Row="1" Classes="card" CornerRadius="4" Padding="14,12">
                <Grid ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0" Classes="cta" Content="🔍  Scan hardware" MinWidth="150"
                            VerticalAlignment="Top"
                            IsEnabled="{Binding !IsScanning}"
                            Command="{Binding ScanCommand}"/>
                    <TextBlock Grid.Column="1" Margin="14,0,0,0" TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppTextPrimary}"
                               Text="{Binding HardwareSummary}"/>
                </Grid>
            </Border>

            <!-- Icon legend: what the Fit + API icons in the list mean -->
            <StackPanel Grid.Row="2" Spacing="2">
                <TextBlock Classes="muted" FontSize="12"
                           Text="Fit:   ✅ comfortable      🟡 tight      🔴 too large for your memory"/>
                <TextBlock Classes="muted" FontSize="12"
                           Text="APIs:   💬 text chat      🛠 tools (agent mode)      👁 vision (images)      🧠 reasoning"/>
            </StackPanel>

            <!-- Filters: use case + API + quant + context + downloaded-only toggle (wraps if narrow) -->
            <WrapPanel Grid.Row="3">
                <StackPanel Margin="0,0,22,6">
                    <TextBlock Classes="label" Text="Use case"/>
                    <ComboBox Width="150" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:CategoryOption">
                                <TextBlock Text="{Binding Label}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Margin="0,0,22,6">
                    <TextBlock Classes="label" Text="API"/>
                    <ComboBox Width="140" ItemsSource="{Binding ApiFilters}" SelectedItem="{Binding SelectedApi}"
                              ToolTip.Tip="Show only models that support this capability">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ApiOption">
                                <TextBlock Text="{Binding Label}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Margin="0,0,22,6">
                    <TextBlock Classes="label" Text="Quant"/>
                    <ComboBox Width="120" ItemsSource="{Binding Quants}" SelectedItem="{Binding SelectedQuant}"/>
                </StackPanel>
                <StackPanel Margin="0,0,22,6">
                    <TextBlock Classes="label" Text="Context"/>
                    <ComboBox Width="110" ItemsSource="{Binding Contexts}" SelectedItem="{Binding SelectedContext}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ContextOption">
                                <TextBlock Text="{Binding Label}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Margin="0,0,0,6" VerticalAlignment="Bottom">
                    <TextBlock Classes="label" Text="Show"/>
                    <ToggleSwitch IsChecked="{Binding DownloadedOnly}"
                                  OnContent="Downloaded only" OffContent="All models"
                                  ToolTip.Tip="Show only models you've already downloaded"/>
                </StackPanel>
            </WrapPanel>

            <!-- Ranked model list -->
            <Border Grid.Row="4" Classes="card" CornerRadius="4" Padding="0" ClipToBounds="True">
                <Grid RowDefinitions="Auto,*">
                    <!-- column header -->
                    <Grid Grid.Row="0" ColumnDefinitions="36,*,70,96,72,64,116" Margin="14,10,14,8">
                        <TextBlock Grid.Column="0" Classes="colhead" Text="Fit"/>
                        <TextBlock Grid.Column="1" Classes="colhead" Text="Model"/>
                        <TextBlock Grid.Column="2" Classes="colhead" Text="Tokens"/>
                        <TextBlock Grid.Column="3" Classes="colhead" Text="APIs"/>
                        <TextBlock Grid.Column="4" Classes="colhead" Text="Size"/>
                        <TextBlock Grid.Column="5" Classes="colhead" Text="Quant"/>
                        <TextBlock Grid.Column="6" Classes="colhead" Text=""/>
                    </Grid>
                    <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                            Background="{DynamicResource AppSurfaceBorderBrush}"/>

                    <ListBox Grid.Row="1" Classes="models" ItemsSource="{Binding Models}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ModelRecommendation" x:CompileBindings="False">
                                <Border Padding="14,7" ToolTip.Tip="{Binding FitNote}">
                                    <Grid ColumnDefinitions="36,*,70,96,72,64,116" VerticalAlignment="Center">
                                        <TextBlock Grid.Column="0" Text="{Binding Symbol}" FontSize="16"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   Foreground="{DynamicResource AppTextPrimary}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                                        <!-- Max context window (tokens) the model supports -->
                                        <TextBlock Grid.Column="2" Text="{Binding TokensDisplay}" Classes="muted"
                                                   VerticalAlignment="Center"
                                                   ToolTip.Tip="Largest context window (tokens) the model supports"/>

                                        <!-- API support: what the model can interact with, as icons -->
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="5"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="💬" ToolTip.Tip="Text chat"/>
                                            <TextBlock Text="🛠" IsVisible="{Binding HasTools}"
                                                       ToolTip.Tip="Tool / function calling — needed for Project (agent) mode"/>
                                            <TextBlock Text="👁" IsVisible="{Binding HasVision}"
                                                       ToolTip.Tip="Vision — accepts image input"/>
                                            <TextBlock Text="🧠" IsVisible="{Binding HasReasoning}"
                                                       ToolTip.Tip="Native reasoning / thinking"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="4" Text="{Binding SizeDisplay}" Classes="muted"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="{Binding Quant}" Classes="muted"
                                                   VerticalAlignment="Center"/>

                                        <!-- Action: appears on the selected row; Download or Remove by install state -->
                                        <Panel Grid.Column="6"
                                               IsVisible="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}">
                                            <Button Classes="cta rowaction" Content="Download"
                                                    IsVisible="{Binding !IsInstalled}"
                                                    Command="{Binding DataContext.DownloadModelCommand,
                                                               RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Classes="ghost rowaction" Content="Remove"
                                                    IsVisible="{Binding IsInstalled}"
                                                    Command="{Binding DataContext.RemoveModelCommand,
                                                               RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Panel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Empty hint (e.g. "Downloaded" with nothing installed) -->
                    <TextBlock Grid.Row="1" Classes="muted" IsVisible="{Binding IsEmpty}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Text="No models to show."/>
                </Grid>
            </Border>

            <!-- Status line (download / remove progress) -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="10"
                        IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <ProgressBar IsIndeterminate="True" Width="120" VerticalAlignment="Center"
                             IsVisible="{Binding IsBusy}"/>
                <TextBlock Text="{Binding StatusMessage}" Classes="muted" VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Button Grid.Row="6" Classes="cta" Content="Close" Click="OnClose"
                    HorizontalAlignment="Right" MinWidth="100"/>
        </Grid>
    </Border>

</Window>
