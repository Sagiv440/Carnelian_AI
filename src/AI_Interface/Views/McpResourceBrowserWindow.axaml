<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AI_Interface.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="560"
        x:Class="AI_Interface.Views.McpResourceBrowserWindow"
        x:DataType="vm:McpResourceBrowserViewModel"
        Width="640" Height="560"
        MinWidth="520" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Title="Attach MCP Resource">

    <Design.DataContext>
        <vm:McpResourceBrowserViewModel/>
    </Design.DataContext>

    <Border Classes="card" CornerRadius="4" Margin="14" Padding="18">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" RowSpacing="10">

            <StackPanel Grid.Row="0">
                <TextBlock Classes="brand" Text="Attach MCP resource"/>
                <TextBlock Classes="muted" TextWrapping="Wrap"
                           Text="Pick resources from your connected MCP servers to attach as context for your next message."/>
            </StackPanel>

            <Button Grid.Row="1" Classes="ghost" Content="⟳ Reload" HorizontalAlignment="Left"
                    Command="{Binding LoadCommand}"/>

            <!-- Resource list -->
            <Border Grid.Row="2" Classes="card" CornerRadius="4" Padding="2" ClipToBounds="True">
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Resources}" Margin="6">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:McpResourceRow">
                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,3">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Margin="2,0,0,0">
                                        <TextBlock Text="{Binding Label}" Foreground="{DynamicResource AppTextPrimary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Description}" Classes="muted" FontSize="11"
                                                   TextTrimming="CharacterEllipsis" IsVisible="{Binding HasDescription}"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="#33808080" CornerRadius="3" Padding="5,1"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ServerName}" FontSize="10"
                                                   Foreground="{DynamicResource AppTextSecondary}"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Status line -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="10"
                        IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <ProgressBar IsIndeterminate="True" Width="110" VerticalAlignment="Center"
                             IsVisible="{Binding IsBusy}"/>
                <TextBlock Text="{Binding StatusMessage}" Classes="muted" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Classes="ghost" Content="Cancel" Click="OnCancel" MinWidth="90"/>
                <Button Classes="cta" Content="Attach selected" Command="{Binding AttachCommand}" MinWidth="120"/>
            </StackPanel>
        </Grid>
    </Border>

</Window>
