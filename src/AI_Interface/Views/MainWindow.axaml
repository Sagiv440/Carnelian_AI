<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AI_Interface.ViewModels"
        xmlns:models="using:AI_Interface.Models"
        xmlns:conv="using:AI_Interface.Converters"
        xmlns:beh="using:AI_Interface.Behaviors"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="AI_Interface.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app-logo.ico"
        Width="1000" Height="700"
        MinWidth="780" MinHeight="520"
        Title="AI Interface — Local AI">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <conv:PathToBitmapConverter x:Key="PathToBitmap"/>
        <conv:ProviderTagConverter x:Key="ProviderTag"/>

        <!-- One row of a structured activity feed: a tool call (caret · icon · title · target · status,
             expandable to its result) or the model's interim narration (a muted note). Shared by the
             single-agent feed AND each delegation card's feed (Phase 3B) so they render identically. -->
        <DataTemplate x:Key="ActivityRowTemplate" x:DataType="vm:ActivityStepViewModel">
            <Panel>
                <!-- Note: the model's interim narration, muted + italic, indented to the title
                     gutter so it lines up with the tool rows' text -->
                <SelectableTextBlock IsVisible="{Binding IsNote}"
                                     Text="{Binding Text}" TextWrapping="Wrap"
                                     FontStyle="Italic" Margin="34,3,0,3"
                                     Foreground="{DynamicResource AppTextSecondary}"/>

                <!-- Tool call: a compact row (caret · icon · title · target · status),
                     clickable to reveal the result only when there is one -->
                <StackPanel IsVisible="{Binding !IsNote}">
                    <ToggleButton Classes="activityRow"
                                  Classes.running="{Binding IsRunning}"
                                  IsChecked="{Binding IsExpanded}"
                                  IsEnabled="{Binding HasResult}"
                                  ToolTip.Tip="{Binding Detail}">
                        <Grid ColumnDefinitions="16,Auto,Auto,*,Auto"
                              VerticalAlignment="Center">
                            <!-- Caret: only present when there's a result to expand;
                                 resultless rows hide it entirely so they look inert -->
                            <TextBlock Grid.Column="0" Classes="activityCaret"
                                       Text="▸"
                                       IsVisible="{Binding ShowCollapsedCaret}"/>
                            <TextBlock Grid.Column="0" Classes="activityCaret"
                                       Text="▾"
                                       IsVisible="{Binding IsExpanded}"/>
                            <!-- Fixed-width centered icon gutter keeps titles aligned -->
                            <TextBlock Grid.Column="1" Classes="activityIcon"
                                       Text="{Binding Icon}"/>
                            <!-- Title -->
                            <TextBlock Grid.Column="2" Text="{Binding Title}"
                                       FontWeight="SemiBold" VerticalAlignment="Center"
                                       Margin="6,0,0,0"
                                       Foreground="{DynamicResource AppTextPrimary}"/>
                            <!-- Target/command: muted monospace, one line, ellipsis -->
                            <TextBlock Grid.Column="3" Text="{Binding Detail}"
                                       Classes="muted" VerticalAlignment="Center"
                                       FontFamily="Cascadia Code,Consolas,monospace"
                                       FontSize="12" TextTrimming="CharacterEllipsis"
                                       Margin="8,0,8,0"/>
                            <!-- Status glyph, tinted by state (running/done/failed) -->
                            <TextBlock Grid.Column="4" Classes="activityStatus"
                                       Classes.done="{Binding Done}"
                                       Classes.failed="{Binding Failed}"
                                       Text="{Binding StatusGlyph}"/>
                        </Grid>
                    </ToggleButton>

                    <!-- Result body (when expanded): a tight hairline card, monospace -->
                    <Border Classes="activityResult"
                            IsVisible="{Binding IsExpanded}">
                        <SelectableTextBlock Text="{Binding Result}" TextWrapping="Wrap"
                                             FontFamily="Cascadia Code,Consolas,monospace"
                                             FontSize="12"
                                             Foreground="{DynamicResource AppTextSecondary}"/>
                    </Border>
                </StackPanel>
            </Panel>
        </DataTemplate>
    </Window.Resources>

    <Window.Styles>
        <!-- Sidebar nav tabs (Button.nav / .active) live in Styles/ControlStyles.axaml (shared with Settings) -->

        <!-- Sidebar Chat Log / Files tabs -->
        <Style Selector="Button.tab">
            <Setter Property="Padding" Value="11,5"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}"/>
        </Style>
        <Style Selector="Button.tab /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.tab.active">
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.tab.active /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#33F2542D"/>
        </Style>

        <!-- Project file tree -->
        <Style Selector="TreeView.files">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TreeView.files TreeViewItem">
            <!-- ReflectionBinding: resolve against each item's FileNode, not the window's x:DataType. -->
            <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded, Mode=TwoWay}"/>
        </Style>

        <!-- Flat log rows: full-width, left-aligned. User turns get a faint panel; AI turns sit on the editor bg. -->
        <Style Selector="Border.logrow">
            <Setter Property="Margin" Value="2,2"/>
            <Setter Property="Padding" Value="8,7"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Border.logrow.user">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Role marker dot: accent for the AI, muted for you -->
        <Style Selector="Ellipse.rolemark">
            <Setter Property="Width" Value="7"/>
            <Setter Property="Height" Value="7"/>
            <Setter Property="Fill" Value="{DynamicResource AppAccentBrush}"/>
        </Style>
        <Style Selector="Ellipse.rolemark.user">
            <Setter Property="Fill" Value="{DynamicResource AppTextSecondary}"/>
        </Style>

        <!-- Collapsible "Thinking" disclosure + body -->
        <Style Selector="ToggleButton.reasoning">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}"/>
        </Style>
        <Style Selector="ToggleButton.reasoning /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ToggleButton.reasoning:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ToggleButton.reasoning:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
        </Style>
        <Style Selector="Border.reasoningBody">
            <Setter Property="Margin" Value="1,3,0,3"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
            <Setter Property="BorderThickness" Value="2,0,0,0"/>
        </Style>

        <!-- ====================================================================
             Orchestrator delegation cards — one collapsible sub-task per
             specialist the lead handed work to. Reads as a nested subordinate
             of the assistant answer: a slight left indent + a hairline left
             accent rule, calmer than the answer itself. Flat, sharp, hairline.
             ==================================================================== -->

        <!-- Subordinate card: indented under the lead, with a left accent rule -->
        <Style Selector="Border.delegation">
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>

        <!-- Header row toggle: full-width, flat; click anywhere toggles the body -->
        <Style Selector="ToggleButton.delegationHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
        </Style>
        <Style Selector="ToggleButton.delegationHeader /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ToggleButton.delegationHeader:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#10808080"/>
        </Style>
        <Style Selector="ToggleButton.delegationHeader:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Disclosure triangle for the header -->
        <Style Selector="TextBlock.delegationCaret">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}"/>
        </Style>

        <!-- Status pip: an accent dot while running, neutral when done -->
        <Style Selector="Ellipse.delegationStatus">
            <Setter Property="Width" Value="7"/>
            <Setter Property="Height" Value="7"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Fill" Value="{DynamicResource AppSuccessBrush}"/>
        </Style>
        <Style Selector="Ellipse.delegationStatus.running">
            <Setter Property="Fill" Value="{DynamicResource AppAccentBrush}"/>
        </Style>

        <!-- Body: separated from the header by a hairline, holds the activity log + result -->
        <Style Selector="Border.delegationBody">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
        </Style>

        <!-- Result block: hairline divider + a small label above the specialist's summary -->
        <Style Selector="Border.delegationResult">
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Padding" Value="0,8,0,0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
        </Style>

        <!-- ====================================================================
             Single-agent activity feed rows — a compact, scannable log of tool
             calls (icon · title · target · status) + interim notes. Flat/hairline;
             aligned icon gutter; only resultful rows look clickable. Sits just
             above the delegation cards, so it borrows their disclosure visuals
             but stays tighter (it's a log, not a stack of cards).
             ==================================================================== -->

        <!-- Row toggle: flat, full-width; faint hover only when there's a result to reveal -->
        <Style Selector="ToggleButton.activityRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="3,3"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
        </Style>
        <Style Selector="ToggleButton.activityRow /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ToggleButton.activityRow:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <!-- Only an expandable (enabled) row gets a pointer + hover tint; resultless rows stay inert -->
        <Style Selector="ToggleButton.activityRow:enabled">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="ToggleButton.activityRow:enabled:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#10808080"/>
        </Style>
        <!-- The in-progress action: a faint translucent-accent band so the current step stands out -->
        <Style Selector="ToggleButton.activityRow.running /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#14F2542D"/>
        </Style>

        <!-- Fixed-width, centered icon gutter so titles left-align across rows regardless of glyph width -->
        <Style Selector="TextBlock.activityIcon">
            <Setter Property="Width" Value="18"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Disclosure caret: shown only when there's a result to expand (resultless rows hide it) -->
        <Style Selector="TextBlock.activityCaret">
            <Setter Property="Width" Value="12"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}"/>
        </Style>

        <!-- Status glyph, tinted by state: muted while running, faint green when done, accent on failure -->
        <Style Selector="TextBlock.activityStatus">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}"/>
        </Style>
        <Style Selector="TextBlock.activityStatus.done">
            <Setter Property="Foreground" Value="{DynamicResource AppSuccessBrush}"/>
        </Style>
        <Style Selector="TextBlock.activityStatus.failed">
            <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}"/>
        </Style>

        <!-- Slash-command palette: flat list, tight rows. The highlight is KEYBOARD-DRIVEN — the ListBox is
             Focusable=False and just reflects SelectedIndex, so the selected row must read clearly while the
             list is unfocused. We override PART_ContentPresenter directly (winning over Fluent's focus-gated
             selected brushes) and flatten Fluent's rounded/animated selection: a stronger translucent-accent
             fill PLUS a left accent bar via the presenter's BorderBrush so Enter's target is unmistakable. -->
        <Style Selector="ListBox.slashMenu">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2"/>
        </Style>
        <Style Selector="ListBox.slashMenu ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="CornerRadius" Value="3"/>
        </Style>
        <!-- Flatten Fluent's default item visual: no rounding/fill of its own; we paint state explicitly. -->
        <Style Selector="ListBox.slashMenu ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2,0,0,0"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>
        <!-- Pointer hover: faint neutral wash that reads in both themes (doesn't fight the selection). -->
        <Style Selector="ListBox.slashMenu ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#18808080"/>
        </Style>
        <!-- Selected (the Enter target): translucent-accent fill + a solid accent left bar. Re-assert on
             :selected:pointerover so hover never weakens the active row. -->
        <Style Selector="ListBox.slashMenu ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#33F2542D"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
        </Style>
        <Style Selector="ListBox.slashMenu ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#33F2542D"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
        </Style>

        <!-- Plan checklist rows: default, done (struck-through + muted), active (accent + semibold) -->
        <Style Selector="TextBlock.planText">
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
        </Style>
        <Style Selector="TextBlock.planText.planDone">
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}"/>
            <Setter Property="TextDecorations" Value="Strikethrough"/>
        </Style>
        <Style Selector="TextBlock.planText.planActive">
            <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Result body: hairline-bordered card indented to the title gutter, tight padding -->
        <Style Selector="Border.activityResult">
            <Setter Property="Margin" Value="34,2,0,4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
        </Style>

        <!-- Copy-message button: visibility is bound to the bubble's hover state (see template) -->
        <Style Selector="Button.copy">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.copy /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Code / command block bubble in replies -->
        <Style Selector="Border.codeBubble">
            <Setter Property="Background" Value="{DynamicResource AppInputBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="ClipToBounds" Value="True"/>
        </Style>
        <Style Selector="Border.codeHeader">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,2,5,2"/>
        </Style>

        <!-- Source links -->
        <Style Selector="Button.link">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <!-- Proactive next-step suggestion chips -->
        <Style Selector="Button.suggestion">
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="Padding" Value="11,5"/>
            <Setter Property="CornerRadius" Value="13"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}"/>
        </Style>
        <Style Selector="Button.suggestion /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button.suggestion:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#22F2542D"/>
        </Style>

        <!-- Connection status dot -->
        <Style Selector="Ellipse.status">
            <Setter Property="Width" Value="9"/>
            <Setter Property="Height" Value="9"/>
            <Setter Property="Fill" Value="#6E6E6E"/>
        </Style>
        <Style Selector="Ellipse.status.online">
            <Setter Property="Fill" Value="{DynamicResource AppSuccessBrush}"/>
        </Style>

        <!-- Composer text box blends into its card -->
        <Style Selector="TextBox.composer">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="TextBox.composer:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Attachment chips -->
        <Style Selector="Border.chip">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppSurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style Selector="Button.chipclose">
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Remove button overlaid on an attachment thumbnail -->
        <Style Selector="Button.thumbremove">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.thumbremove /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#B0000000"/>
        </Style>
        <Style Selector="Button.thumbremove:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#D8000000"/>
        </Style>

        <!-- Web-search toggle in the composer toolbar -->
        <Style Selector="ToggleButton.toolToggle">
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="11,5"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>
        <Style Selector="ToggleButton.toolToggle:checked /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#33F2542D"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="Auto,*">

        <!-- ===================== SIDEBAR ===================== -->
        <Border Grid.Column="0" Classes="card" CornerRadius="4" Margin="10" Padding="12" Width="240">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto">
                <TextBlock Grid.Row="0" Classes="brand" Text="AI Interface" Margin="4,2,0,12"/>

                <!-- New Chat -->
                <Button Grid.Row="1" Classes="cta" Content="＋  New Chat"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Command="{Binding NewChatCommand}"/>

                <!-- Project: opens the New Project window -->
                <Button Grid.Row="2" Classes="ghost" Content="📁  Project" Margin="0,8,0,0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Command="{Binding OpenProjectCommand}"
                        ToolTip.Tip="Create a project the agent can edit files and run commands in"/>

                <!-- Tools: a flyout with the LLM Browser + Voice Browser tools. Each entry is grayed out
                     until its prerequisite is set up, with a one-click "Download & Install" offered inline. -->
                <Button Grid.Row="3" Classes="ghost" Content="🛠  Tools" Margin="0,8,0,0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Click="OnToolsOpening"
                        ToolTip.Tip="LLM Browser and Voice Browser tools">
                    <Button.Flyout>
                        <Flyout Placement="Right">
                            <!-- CompileBindings off: popup content binds against the inherited window VM. -->
                            <Border Classes="card" CornerRadius="5" Padding="10" MinWidth="248"
                                    x:CompileBindings="False">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="muted" Text="TOOLS" Margin="2,0,0,2"/>

                                    <!-- LLM Browser (grayed out until Ollama is reachable) -->
                                    <Button Classes="nav" Content="⚙  LLM Browser"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Command="{Binding OpenModelConfigCommand}"
                                            ToolTip.Tip="Hardware-aware model recommender (needs Ollama running)"/>
                                    <StackPanel Spacing="6" Margin="8,0,0,0" IsVisible="{Binding !IsOllamaReady}">
                                        <TextBlock Classes="muted" FontSize="11" TextWrapping="Wrap"
                                                   Text="Ollama isn't running. Install it to use the LLM Browser."/>
                                        <Button Classes="cta" Content="⬇  Download &amp; Install Ollama"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                Command="{Binding InstallOllamaCommand}"/>
                                        <TextBlock Classes="muted" FontSize="11" TextWrapping="Wrap"
                                                   IsVisible="{Binding HasOllamaInstallStatus}"
                                                   Text="{Binding OllamaInstallStatus}"/>
                                    </StackPanel>

                                    <Border Height="1" Margin="0,2"
                                            Background="{DynamicResource AppSurfaceBorderBrush}"/>

                                    <!-- Voice Browser (grayed out until the Piper engine is installed) -->
                                    <Button Classes="nav" Content="🔊  Voice Browser"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Command="{Binding OpenVoiceBrowserCommand}"
                                            ToolTip.Tip="Browse and download Piper voices (needs the Piper engine)"/>
                                    <StackPanel Spacing="6" Margin="8,0,0,0" IsVisible="{Binding !IsPiperReady}">
                                        <TextBlock Classes="muted" FontSize="11" TextWrapping="Wrap"
                                                   Text="The Piper voice engine isn't installed. Install it to use Voice Browser."/>
                                        <Button Classes="cta" Content="⬇  Download &amp; Install Piper"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                Command="{Binding InstallPiperCommand}"/>
                                        <TextBlock Classes="muted" FontSize="11" TextWrapping="Wrap"
                                                   IsVisible="{Binding HasPiperInstallStatus}"
                                                   Text="{Binding PiperInstallStatus}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <!-- Header: plain "CHAT LOG" with no project; Chat Log / Files tabs with a project -->
                <TextBlock Grid.Row="4" Classes="muted" Text="CHAT LOG" Margin="4,16,0,4"
                           IsVisible="{Binding !HasActiveProject}"/>
                <Grid Grid.Row="4" ColumnDefinitions="Auto,Auto,*,Auto" Margin="0,14,0,4"
                      IsVisible="{Binding HasActiveProject}">
                    <Button Grid.Column="0" Classes="tab" Content="Chat Log"
                            Classes.active="{Binding IsChatLogTabSelected}"
                            Command="{Binding ShowChatLogCommand}"/>
                    <Button Grid.Column="1" Classes="tab" Content="Files" Margin="4,0,0,0"
                            Classes.active="{Binding IsFilesTabSelected}"
                            Command="{Binding ShowFilesCommand}"/>
                    <Button Grid.Column="3" Classes="chipclose" Content="⟳" ToolTip.Tip="Refresh files"
                            IsVisible="{Binding IsFilesTabSelected}"
                            Command="{Binding RefreshFilesCommand}"/>
                </Grid>

                <!-- Chat Log: all saved conversations -->
                <ScrollViewer Grid.Row="5" HorizontalScrollBarVisibility="Disabled"
                              IsVisible="{Binding !ShowProjectFiles}">
                    <ItemsControl ItemsSource="{Binding ChatLog}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:CompileBindings="False">
                                <Grid ColumnDefinitions="*,Auto" Margin="0,1">
                                    <Button Grid.Column="0" Classes="nav"
                                            Content="{Binding Title}"
                                            ToolTip.Tip="{Binding Title}"
                                            CommandParameter="{Binding}"
                                            Command="{Binding DataContext.OpenSessionCommand,
                                                       RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    <Button Grid.Column="1" Classes="chipclose" Content="✕" ToolTip.Tip="Delete"
                                            VerticalAlignment="Center"
                                            CommandParameter="{Binding}"
                                            Command="{Binding DataContext.DeleteSessionCommand,
                                                       RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Project files: hierarchical tree with expand/collapse arrows -->
                <ScrollViewer Grid.Row="5" HorizontalScrollBarVisibility="Auto"
                              IsVisible="{Binding ShowProjectFiles}">
                    <TreeView x:Name="ProjectFileTree" Classes="files" ItemsSource="{Binding FileTree}"
                              DoubleTapped="OnFileTreeDoubleTapped">
                        <TreeView.ItemTemplate>
                            <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="vm:FileNode">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <!-- Right-click: folder -> open in file manager; file -> reveal its folder.
                                         CompileBindings off so the menu binds against the row's FileNode. -->
                                    <StackPanel.ContextMenu>
                                        <ContextMenu x:CompileBindings="False">
                                            <MenuItem Header="Open In File Explorer"
                                                      IsVisible="{Binding IsDirectory}"
                                                      Click="OnOpenInFileExplorer"/>
                                            <MenuItem Header="View in Folder"
                                                      IsVisible="{Binding !IsDirectory}"
                                                      Click="OnViewInFolder"/>
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                    <TextBlock Text="{Binding Glyph}"/>
                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource AppTextPrimary}"/>
                                </StackPanel>
                            </TreeDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </ScrollViewer>

                <!-- Active project card (shown only in project mode) -->
                <Border Grid.Row="6" Classes="card" CornerRadius="4" Padding="12,10" Margin="0,10,0,0"
                        IsVisible="{Binding HasActiveProject}">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="📁 PROJECT" Classes="muted"/>
                        <Button Grid.Row="0" Grid.Column="1" Classes="chipclose" Content="✕" ToolTip.Tip="Exit project"
                                VerticalAlignment="Center" Command="{Binding ExitProjectCommand}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="{Binding ActiveProjectName}" FontWeight="SemiBold" Margin="0,2,0,0"
                                   Foreground="{DynamicResource AppTextPrimary}" TextTrimming="CharacterEllipsis"
                                   ToolTip.Tip="{Binding ActiveProjectDirectory}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                   Classes="muted" Margin="0,3,0,0"
                                   IsVisible="{Binding HasProjectSkills}"
                                   Text="{Binding ProjectSkillSummary}"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                   Classes="muted" Margin="0,3,0,0"
                                   IsVisible="{Binding HasProjectDocs}"
                                   Text="📄 AI_DOCS loaded"/>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- ===================== MAIN AREA ===================== -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto,Auto" Margin="0,10,10,10">

            <!-- Top bar: agent picker + model picker + connection dot + settings -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,2,6">

                <!-- Agent picker: the persona applied to every mode. Independent of the model. -->
                <ComboBox MinWidth="160" MaxDropDownHeight="320" VerticalAlignment="Center"
                          ItemsSource="{Binding Agents}"
                          SelectedItem="{Binding SelectedAgent}"
                          PlaceholderText="Agent"
                          ToolTip.Tip="The agent (persona) answering — manage agents in Settings → Agents">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="models:Agent">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Glyph}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                <!-- "team" badge: marks an orchestrator (delegates to specialist agents) -->
                                <Border IsVisible="{Binding IsOrchestrator}" VerticalAlignment="Center"
                                        Background="{DynamicResource AppSurfaceBrush}"
                                        BorderBrush="{DynamicResource AppSurfaceBorderBrush}"
                                        BorderThickness="1" CornerRadius="3" Padding="5,1"
                                        ToolTip.Tip="Team agent — delegates subtasks to specialist agents">
                                    <TextBlock Text="team" FontSize="10" Classes="muted"/>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Ellipse Classes="status" Classes.online="{Binding IsConnected}" VerticalAlignment="Center"
                         ToolTip.Tip="{Binding ConnectionStatus}"/>
                <ComboBox MinWidth="200" MaxDropDownHeight="320" VerticalAlignment="Center"
                          ItemsSource="{Binding Models}"
                          SelectedItem="{Binding SelectedModel}"
                          PlaceholderText="Select model"
                          ToolTip.Tip="{Binding ConnectionStatus}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="models:ChatModel">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Id}" VerticalAlignment="Center"/>
                                <Border Background="#33808080" CornerRadius="3" Padding="5,1"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Provider, Converter={StaticResource ProviderTag}}"
                                               FontSize="10" Foreground="{DynamicResource AppTextSecondary}"/>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Classes="ghost" Content="⚙" FontSize="15" VerticalAlignment="Center"
                        Command="{Binding OpenSettingsCommand}" ToolTip.Tip="Settings"/>
            </StackPanel>

            <!-- Transcript -->
            <Grid Grid.Row="1" Margin="0,0,0,4">
                <!-- HorizontalScrollBarVisibility=Disabled so wrapped text is measured at the real (finite)
                     width, never infinite (matches the chat-log list). The bottom breathing room is a REAL
                     measured spacer child below the list (see end of this StackPanel), NOT ScrollViewer.Padding:
                     Avalonia doesn't reliably include bottom padding in the scroll EXTENT, so a wrapped
                     SelectableTextBlock that under-measures its height by ~a line would still clip the last
                     reply line at the very bottom. The end-of-turn re-scroll lives in the code-behind's
                     OnScrollToEndRequested. -->
                <ScrollViewer x:Name="TranscriptScroll" HorizontalScrollBarVisibility="Disabled" Padding="6,4,8,0">
                    <StackPanel>
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:MessageViewModel">
                                <Border Classes="logrow" Classes.user="{Binding IsUser}">
                                    <Grid ColumnDefinitions="Auto,*">
                                    <Ellipse Grid.Column="0" Classes="rolemark" Classes.user="{Binding IsUser}"
                                             VerticalAlignment="Top" Margin="2,6,10,0"/>
                                    <Panel Grid.Column="1">
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="{Binding Header}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AppTextPrimary}"
                                                   ToolTip.Tip="{Binding ModelName}"/>

                                        <!-- Collapsible reasoning / action log ("how it got to the answer").
                                             Raw monospace block: shown only when there's no structured feed
                                             (e.g. chat-with-thinking); single-agent project runs use the feed below. -->
                                        <StackPanel IsVisible="{Binding ShowWorkBlock}" Margin="0,1">
                                            <ToggleButton Classes="reasoning" HorizontalAlignment="Left"
                                                          IsChecked="{Binding IsWorkExpanded}"
                                                          ToolTip.Tip="Show what the AI did to reach this answer">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="▸" IsVisible="{Binding !IsWorkExpanded}"/>
                                                    <TextBlock Text="▾" IsVisible="{Binding IsWorkExpanded}"/>
                                                    <TextBlock Text="{Binding WorkLabel}"/>
                                                </StackPanel>
                                            </ToggleButton>
                                            <Border Classes="reasoningBody" IsVisible="{Binding IsWorkExpanded}">
                                                <ScrollViewer MaxHeight="280" HorizontalScrollBarVisibility="Disabled"
                                                              beh:AutoScrollToEnd.Enabled="True">
                                                    <SelectableTextBlock Text="{Binding Work}" TextWrapping="Wrap"
                                                                         FontFamily="Cascadia Code,Consolas,monospace" FontSize="12"
                                                                         Foreground="{DynamicResource AppTextSecondary}"/>
                                                </ScrollViewer>
                                            </Border>
                                        </StackPanel>

                                        <!-- Structured activity feed (single-agent project runs): one row per
                                             tool call (icon · title · target · running/done status, with an
                                             expandable result) plus the model's interim narration as note lines.
                                             Reuses the Phase-1 disclosure (WorkLabel + IsWorkExpanded + autoscroll). -->
                                        <StackPanel IsVisible="{Binding HasActivities}" Margin="0,1">
                                            <ToggleButton Classes="reasoning" HorizontalAlignment="Left"
                                                          IsChecked="{Binding IsWorkExpanded}"
                                                          ToolTip.Tip="Show what the AI did to reach this answer">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="▸" IsVisible="{Binding !IsWorkExpanded}"/>
                                                    <TextBlock Text="▾" IsVisible="{Binding IsWorkExpanded}"/>
                                                    <TextBlock Text="{Binding WorkLabel}"/>
                                                </StackPanel>
                                            </ToggleButton>
                                            <Border Classes="reasoningBody" IsVisible="{Binding IsWorkExpanded}">
                                                <ScrollViewer MaxHeight="320" HorizontalScrollBarVisibility="Disabled"
                                                              beh:AutoScrollToEnd.Enabled="True">
                                                    <ItemsControl ItemsSource="{Binding Activities}"
                                                                  ItemTemplate="{StaticResource ActivityRowTemplate}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate><StackPanel Spacing="1"/></ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Border>
                                        </StackPanel>

                                        <!-- Agent plan / checklist (update_plan tool): a compact card the agent
                                             rebuilds wholesale each call; ☑ done (struck-through), ▶ active (accent). -->
                                        <Border IsVisible="{Binding HasPlan}" Margin="0,2" Padding="10,8"
                                                Background="{DynamicResource AppSurfaceBrush}"
                                                BorderBrush="{DynamicResource AppSurfaceBorderBrush}"
                                                BorderThickness="1" CornerRadius="4">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="PLAN" Classes="muted" FontSize="10" FontWeight="SemiBold"/>
                                                <ItemsControl ItemsSource="{Binding Plan}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><StackPanel Spacing="2"/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:PlanStepViewModel">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <TextBlock Text="{Binding Glyph}" VerticalAlignment="Top"
                                                                           Foreground="{DynamicResource AppTextSecondary}"/>
                                                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                                                           Classes="planText"
                                                                           Classes.planDone="{Binding IsDone}"
                                                                           Classes.planActive="{Binding IsActive}"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <!-- Phased plan (update_plan 'phases'): named phases, each with its own
                                             steps. Phases win the plan slot over the flat checklist above. -->
                                        <Border IsVisible="{Binding HasPhases}" Margin="0,2" Padding="10,8"
                                                Background="{DynamicResource AppSurfaceBrush}"
                                                BorderBrush="{DynamicResource AppSurfaceBorderBrush}"
                                                BorderThickness="1" CornerRadius="4">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="PLAN" Classes="muted" FontSize="10" FontWeight="SemiBold"/>
                                                <ItemsControl ItemsSource="{Binding Phases}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><StackPanel Spacing="6"/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:PlanPhaseViewModel">
                                                            <StackPanel Spacing="2">
                                                                <!-- Phase header -->
                                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                                    <TextBlock Text="{Binding Glyph}" VerticalAlignment="Top"
                                                                               Foreground="{DynamicResource AppTextSecondary}"/>
                                                                    <TextBlock Text="{Binding Name}" TextWrapping="Wrap"
                                                                               FontWeight="SemiBold"
                                                                               Classes="planText"
                                                                               Classes.planDone="{Binding IsDone}"
                                                                               Classes.planActive="{Binding IsActive}"/>
                                                                </StackPanel>
                                                                <!-- Steps within the phase (indented) -->
                                                                <ItemsControl ItemsSource="{Binding Steps}" Margin="20,0,0,0">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate><StackPanel Spacing="2"/></ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate x:DataType="vm:PlanStepViewModel">
                                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                                <TextBlock Text="{Binding Glyph}" VerticalAlignment="Top"
                                                                                           Foreground="{DynamicResource AppTextSecondary}"/>
                                                                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                                                                           Classes="planText"
                                                                                           Classes.planDone="{Binding IsDone}"
                                                                                           Classes.planActive="{Binding IsActive}"/>
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <!-- Orchestrator delegations: one collapsible card per subtask handed to a
                                             specialist. Reads as a nested sub-task under the lead — a slight left
                                             indent and a hairline left accent rule mark it as subordinate to the answer. -->
                                        <StackPanel IsVisible="{Binding HasDelegations}" Spacing="4" Margin="0,2">
                                            <ItemsControl ItemsSource="{Binding Delegations}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><StackPanel Spacing="4"/></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:DelegationStepViewModel">
                                                        <!-- Hairline left accent rule sits behind the card to mark it as a
                                                             child of the lead's answer without competing with it. -->
                                                        <Border Background="{DynamicResource AppAccentBrush}"
                                                                CornerRadius="4" Padding="2,0,0,0">
                                                            <Border Classes="delegation">
                                                                <StackPanel>
                                                                    <!-- Header (always visible): caret · glyph+name · task · status -->
                                                                    <ToggleButton Classes="delegationHeader"
                                                                                  IsChecked="{Binding IsExpanded}"
                                                                                  ToolTip.Tip="{Binding Task}">
                                                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto" >
                                                                            <TextBlock Grid.Column="0" Classes="delegationCaret"
                                                                                       Text="▸" IsVisible="{Binding !IsExpanded}"
                                                                                       Margin="0,0,6,0"/>
                                                                            <TextBlock Grid.Column="0" Classes="delegationCaret"
                                                                                       Text="▾" IsVisible="{Binding IsExpanded}"
                                                                                       Margin="0,0,6,0"/>
                                                                            <TextBlock Grid.Column="1" Text="{Binding Header}"
                                                                                       FontWeight="SemiBold" VerticalAlignment="Center"
                                                                                       Foreground="{DynamicResource AppTextPrimary}"/>
                                                                            <!-- Task brief: muted, one line, ellipsis when long -->
                                                                            <TextBlock Grid.Column="2" Text="{Binding Task}"
                                                                                       Classes="muted" VerticalAlignment="Center"
                                                                                       TextTrimming="CharacterEllipsis"
                                                                                       Margin="8,0,8,0"/>
                                                                            <!-- Status: accent pip + "running" while working, green pip + "done" after -->
                                                                            <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                                                        Spacing="5" VerticalAlignment="Center">
                                                                                <Ellipse Classes="delegationStatus"
                                                                                         Classes.running="{Binding IsRunning}"/>
                                                                                <TextBlock Text="running" Classes="muted"
                                                                                           VerticalAlignment="Center"
                                                                                           IsVisible="{Binding IsRunning}"/>
                                                                                <TextBlock Text="done" Classes="muted"
                                                                                           VerticalAlignment="Center"
                                                                                           IsVisible="{Binding !IsRunning}"/>
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </ToggleButton>

                                                                    <!-- Body (when expanded): the specialist's activity log + result -->
                                                                    <Border Classes="delegationBody" IsVisible="{Binding IsExpanded}">
                                                                        <ScrollViewer MaxHeight="260" HorizontalScrollBarVisibility="Disabled">
                                                                            <StackPanel>
                                                                                <!-- Full task brief (the header truncates it) -->
                                                                                <SelectableTextBlock Text="{Binding Task}" TextWrapping="Wrap"
                                                                                                     IsVisible="{Binding Task, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                                                                     Foreground="{DynamicResource AppTextPrimary}"
                                                                                                     Margin="0,0,0,6"/>
                                                                                <!-- The specialist's structured activity feed — same rows as a
                                                                                     single-agent run (Phase 3B), via the shared row template -->
                                                                                <ItemsControl ItemsSource="{Binding Activities}"
                                                                                              IsVisible="{Binding HasActivities}"
                                                                                              ItemTemplate="{StaticResource ActivityRowTemplate}">
                                                                                    <ItemsControl.ItemsPanel>
                                                                                        <ItemsPanelTemplate><StackPanel Spacing="1"/></ItemsPanelTemplate>
                                                                                    </ItemsControl.ItemsPanel>
                                                                                </ItemsControl>
                                                                                <!-- Final summary, set apart by a hairline divider + label -->
                                                                                <Border Classes="delegationResult"
                                                                                        IsVisible="{Binding Result, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                                                    <StackPanel Spacing="3">
                                                                                        <TextBlock Text="RESULT" Classes="muted"
                                                                                                   FontSize="10" FontWeight="SemiBold"/>
                                                                                        <SelectableTextBlock Text="{Binding Result}" TextWrapping="Wrap"
                                                                                                             Foreground="{DynamicResource AppTextPrimary}"/>
                                                                                    </StackPanel>
                                                                                </Border>
                                                                            </StackPanel>
                                                                        </ScrollViewer>
                                                                    </Border>
                                                                </StackPanel>
                                                            </Border>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <!-- Final answer: prose flows as text, code/commands render as bubbles -->
                                        <ItemsControl ItemsSource="{Binding Segments}"
                                                      HorizontalAlignment="Stretch">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><StackPanel Spacing="2"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:MessageSegment">
                                                    <Panel>
                                                        <!-- Prose -->
                                                        <SelectableTextBlock IsVisible="{Binding !IsCode}"
                                                                             Text="{Binding Text}" TextWrapping="Wrap"
                                                                             Foreground="{DynamicResource AppTextPrimary}"/>

                                                        <!-- Code / command bubble -->
                                                        <Border IsVisible="{Binding IsCode}" Classes="codeBubble">
                                                            <Grid RowDefinitions="Auto,Auto">
                                                                <Border Grid.Row="0" Classes="codeHeader">
                                                                    <Grid ColumnDefinitions="*,Auto">
                                                                        <TextBlock Grid.Column="0" Classes="muted"
                                                                                   Text="{Binding LanguageLabel}"
                                                                                   FontSize="11" VerticalAlignment="Center"/>
                                                                        <Button Grid.Column="1" Classes="copy" Content="📋"
                                                                                ToolTip.Tip="Copy code" Click="OnCopyCode"/>
                                                                    </Grid>
                                                                </Border>
                                                                <!-- No inner ScrollViewer: the bubble sizes exactly to the wrapped
                                                                     code so the last lines can never be clipped (a ScrollViewer
                                                                     under-measured the text height). Long code just makes a taller
                                                                     message; the transcript scrolls. -->
                                                                <SelectableTextBlock Grid.Row="1" Text="{Binding Text}" TextWrapping="Wrap"
                                                                                     Margin="12,8,12,10"
                                                                                     FontFamily="Cascadia Code,Consolas,monospace"
                                                                                     FontSize="12.5"
                                                                                     Foreground="{DynamicResource AppTextPrimary}"/>
                                                            </Grid>
                                                        </Border>
                                                    </Panel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Attached files -->
                                        <ItemsControl ItemsSource="{Binding Attachments}"
                                                      IsVisible="{Binding HasAttachments}" Margin="0,6,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:CompileBindings="False">
                                                    <StackPanel Width="120" Margin="0,0,8,4">
                                                        <Border CornerRadius="3" ClipToBounds="True" Height="84"
                                                                IsVisible="{Binding IsPhoto}">
                                                            <Image Stretch="UniformToFill"
                                                                   Source="{Binding Path, Converter={StaticResource PathToBitmap}}"/>
                                                        </Border>
                                                        <Border CornerRadius="3" Height="84" IsVisible="{Binding !IsPhoto}"
                                                                Background="{DynamicResource AppSurfaceBrush}"
                                                                BorderBrush="{DynamicResource AppSurfaceBorderBrush}" BorderThickness="1">
                                                            <TextBlock Text="{Binding Glyph}" FontSize="30"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding FileName}" Classes="muted"
                                                                   TextTrimming="CharacterEllipsis" MaxWidth="116"
                                                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Expander Margin="0,10,0,0" IsVisible="{Binding HasSources}" Header="Sources">
                                            <ItemsControl ItemsSource="{Binding Sources}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:CompileBindings="False">
                                                        <StackPanel Margin="0,5">
                                                            <Button Classes="link"
                                                                    Content="{Binding Title}"
                                                                    CommandParameter="{Binding Url}"
                                                                    Command="{Binding DataContext.OpenUrlCommand,
                                                                               RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                            <TextBlock Text="{Binding Url}" Classes="muted"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>

                                        <!-- Proactive next-step suggestions: click a chip to drop it into the composer -->
                                        <ItemsControl ItemsSource="{Binding Suggestions}"
                                                      IsVisible="{Binding HasSuggestions}" Margin="0,10,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:CompileBindings="False">
                                                    <Button Classes="suggestion" Content="{Binding}"
                                                            CommandParameter="{Binding}"
                                                            Command="{Binding DataContext.UseSuggestionCommand,
                                                                       RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- Message actions (top-right, appear on hover). Rerun only for user prompts. -->
                                    <StackPanel Orientation="Horizontal" Spacing="4"
                                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0"
                                                IsVisible="{Binding $parent[Border].IsPointerOver}">
                                        <Button Classes="copy" Click="OnRerunMessage" Content="↻"
                                                ToolTip.Tip="Rerun this prompt"
                                                IsVisible="{Binding IsUser}"/>
                                        <Button Classes="copy" Click="OnSpeakMessage" Content="{Binding SpeakGlyph}"
                                                ToolTip.Tip="Read aloud"
                                                IsVisible="{Binding !IsUser}"/>
                                        <Button Classes="copy" Click="OnCopyMessage" Content="📋"
                                                ToolTip.Tip="Copy message"/>
                                    </StackPanel>
                                    </Panel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- Bottom breathing room as a real measured child (see ScrollViewer comment): keeps the
                         last reply's final line inside the scroll extent despite the text-wrap under-measure. -->
                    <Border Height="48" Background="Transparent" IsHitTestVisible="False"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Status line (only while busy) — kept aligned with the centered composer. Shows the live
                 "current action" (Phase 3A): in Project mode StatusText carries the icon · step · target
                 of the running tool, so the user sees what's happening without opening the activity feed. -->
            <Border Grid.Row="2" Classes="card" CornerRadius="4" Margin="0,4" Padding="14,7"
                    MaxWidth="760" IsVisible="{Binding IsBusy}">
                <Grid ColumnDefinitions="Auto,*">
                    <ProgressBar Grid.Column="0" IsIndeterminate="True" Width="120"
                                 VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Grid.Column="1" Text="{Binding StatusText}" Classes="muted"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>

            <!-- Composer: centered at the bottom, capped width (not edge-to-edge) -->
            <Border Grid.Row="3" Classes="card" CornerRadius="4" Margin="0,4,0,8" Padding="8"
                    MaxWidth="760">
                <StackPanel Spacing="6">

                    <!-- Staged attachment chips -->
                    <ItemsControl ItemsSource="{Binding Attachments}" IsVisible="{Binding HasAttachments}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:CompileBindings="False">
                                <StackPanel Width="120" Margin="0,0,8,0">
                                    <Panel>
                                        <Border CornerRadius="3" ClipToBounds="True" Height="84"
                                                IsVisible="{Binding IsPhoto}">
                                            <Image Stretch="UniformToFill"
                                                   Source="{Binding Path, Converter={StaticResource PathToBitmap}}"/>
                                        </Border>
                                        <Border CornerRadius="3" Height="84" IsVisible="{Binding !IsPhoto}"
                                                Background="{DynamicResource AppSurfaceBrush}"
                                                BorderBrush="{DynamicResource AppSurfaceBorderBrush}" BorderThickness="1">
                                            <TextBlock Text="{Binding Glyph}" FontSize="30"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Button Classes="thumbremove" Content="✕" ToolTip.Tip="Remove"
                                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4"
                                                CommandParameter="{Binding}"
                                                Command="{Binding DataContext.RemoveAttachmentCommand,
                                                           RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    </Panel>
                                    <TextBlock Text="{Binding FileName}" Classes="muted"
                                               TextTrimming="CharacterEllipsis" MaxWidth="116"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Staged MCP resource chips -->
                    <ItemsControl ItemsSource="{Binding McpResources}" IsVisible="{Binding HasMcpResources}"
                                  Margin="0,4,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:CompileBindings="False">
                                <Border Background="{DynamicResource AppSurfaceBrush}"
                                        BorderBrush="{DynamicResource AppSurfaceBorderBrush}" BorderThickness="1"
                                        CornerRadius="3" Padding="6,2" Margin="0,0,6,4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="🔌" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Label}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="220"
                                                   ToolTip.Tip="{Binding Label}"/>
                                        <Button Content="✕" Classes="ghost" Padding="3,0" MinWidth="0" FontSize="11"
                                                ToolTip.Tip="Remove"
                                                Command="{Binding DataContext.RemoveMcpResourceCommand,
                                                           RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Slash-command palette: opens when the message starts with "/". Type to filter,
                         ↑/↓ to move, Enter/Tab or click to run (keyboard handled in MainWindow.axaml.cs). -->
                    <Border IsVisible="{Binding IsSlashMenuOpen}" Margin="0,0,0,4"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppSurfaceBorderBrush}"
                            BorderThickness="1" CornerRadius="4">
                        <ListBox x:Name="SlashList" Classes="slashMenu" Focusable="False" MaxHeight="240"
                                 ItemsSource="{Binding SlashCommands}"
                                 SelectedIndex="{Binding SelectedSlashIndex, Mode=TwoWay}"
                                 Tapped="OnSlashItemTapped"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:SlashCommand">
                                    <!-- Name column hugs the longest command (/auto-read) with a consistent
                                         gutter, so it never clips and never strands the description. -->
                                    <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Grid.Column="0" Text="{Binding Display}"
                                                   FontFamily="Cascadia Code,Consolas,monospace"
                                                   Foreground="{DynamicResource AppAccentBrush}"
                                                   VerticalAlignment="Center" MinWidth="84"
                                                   Margin="0,0,14,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Description}" Classes="muted"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- Text input -->
                    <TextBox x:Name="InputBox" Classes="composer"
                             Text="{Binding InputText}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MaxHeight="160"
                             PlaceholderText="Type a message…  (Enter to send, Shift+Enter for a new line)"/>

                    <!-- Toolbar: attach + search-scope dropdown + thinking toggle (left), auto-read + send/stop (right) -->
                    <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto">
                        <Button Grid.Column="0" Classes="ghost" Content="📎" FontSize="15"
                                ToolTip.Tip="Attach files">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuItem Header="🖼  Photos" Command="{Binding AttachPhotosCommand}"/>
                                    <MenuItem Header="📄  Documents &amp; text" Command="{Binding AttachDocumentsCommand}"/>
                                    <MenuItem Header="🔌  From MCP server…" Command="{Binding AttachMcpResourcesCommand}"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>

                        <!-- Search scope: Local / Web / Deep (hidden while a project is active) -->
                        <ComboBox Grid.Column="1" Margin="8,0,0,0" MinWidth="150" VerticalAlignment="Center"
                                  ItemsSource="{Binding SearchModes}"
                                  SelectedItem="{Binding SelectedSearchMode}"
                                  IsVisible="{Binding !HasActiveProject}"
                                  ToolTip.Tip="Choose how this prompt is answered">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ModeOption">
                                    <TextBlock Text="{Binding Label}" ToolTip.Tip="{Binding Description}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <ToggleButton Grid.Column="2" Classes="toolToggle" Margin="8,0,0,0"
                                      IsChecked="{Binding ThinkingEnabled}"
                                      Content="🧠 Thinking"
                                      ToolTip.Tip="Make the AI plan what it needs to do before answering (effort set in Settings)"/>

                        <!-- Auto-read: speak every reply aloud (icon-only toggle; accent when on).
                             Shown only when a voice is set up. -->
                        <ToggleButton Grid.Column="3" Classes="toolToggle" HorizontalAlignment="Right"
                                      Margin="8,0,8,0" FontSize="15"
                                      IsChecked="{Binding AutoSpeakEnabled}"
                                      IsVisible="{Binding IsVoiceConfigured}"
                                      Content="🔊"
                                      ToolTip.Tip="Auto-read: read each reply aloud automatically, in the voice that matches its language"/>

                        <Button Grid.Column="4" Classes="cta" Content="Send" MinWidth="96" Margin="8,0,0,0"
                                Command="{Binding SendCommand}"
                                IsVisible="{Binding !IsBusy}"/>
                        <Button Grid.Column="5" Content="Stop" MinWidth="96" Margin="8,0,0,0"
                                Command="{Binding StopCommand}"
                                IsVisible="{Binding IsBusy}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Startup launcher overlay: the window opens on this and switches to the chat UI in place when a
             choice is made (recent project / Local Chat / open a project). Covers both columns, on top. -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" IsVisible="{Binding ShowStartupLauncher}"
                Background="{DynamicResource AppWindowBackground}">
            <Border Classes="card" CornerRadius="6" Width="480" Padding="26,24"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">

                    <TextBlock Grid.Row="0" Classes="brand" FontSize="20" Text="AI Interface"/>
                    <TextBlock Grid.Row="1" Classes="muted" Margin="0,3,0,18"
                               Text="Open a recent project, or start chatting locally."/>

                    <!-- Primary action: start a local (no-project) chat. -->
                    <Button Grid.Row="2" Classes="cta" Content="💬   Local Chat"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Padding="0,13" FontSize="15" Command="{Binding StartLocalChatCommand}"/>

                    <!-- Recent projects -->
                    <StackPanel Grid.Row="3" Margin="0,22,0,0">
                        <TextBlock Classes="navheader" Text="RECENT PROJECTS" Margin="2,0,0,6"/>

                        <!-- Empty state -->
                        <Border IsVisible="{Binding !HasStartupRecentProjects}" Padding="0,16">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="📂" FontSize="26" Opacity="0.5" HorizontalAlignment="Center"/>
                                <TextBlock Classes="muted" HorizontalAlignment="Center" Text="No recent projects yet."/>
                                <TextBlock Classes="muted" HorizontalAlignment="Center" Text="Open one below to get started."/>
                            </StackPanel>
                        </Border>

                        <!-- Recent list -->
                        <ScrollViewer MaxHeight="248" HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      IsVisible="{Binding HasStartupRecentProjects}">
                            <ItemsControl ItemsSource="{Binding StartupRecentProjects}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><StackPanel Spacing="1"/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:RecentProject">
                                        <!-- CompileBindings off: reach the window VM's command + bind the row's RecentProject. -->
                                        <Button Classes="nav" Padding="10,7" x:CompileBindings="False"
                                                Command="{Binding DataContext.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{Binding Directory}">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <TextBlock Grid.Column="0" Text="📁" FontSize="15"
                                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AppTextPrimary}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Directory}" Classes="muted" FontSize="11"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- Footer: open a project not in the list (New / Open dialog). -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                                Spacing="10" Margin="0,18,0,0">
                        <Button Classes="ghost" Content="Open a project…" Command="{Binding OpenProjectCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>

</Window>
