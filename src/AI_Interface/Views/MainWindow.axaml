<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AI_Interface.ViewModels"
        xmlns:models="using:AI_Interface.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="AI_Interface.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="1000" Height="700"
        MinWidth="720" MinHeight="480"
        Title="AI Interface — Local AI">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.bubble">
            <Setter Property="Margin" Value="6,4"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="MaxWidth" Value="700"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Background" Value="#22888888"/>
        </Style>
        <Style Selector="Border.bubble.user">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Background" Value="#332D7DD2"/>
        </Style>
        <Style Selector="Button.link">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#4F9DEC"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- Top bar: model, mode, connection -->
        <Border Grid.Row="0" Padding="10,8" Background="#11808080">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Text="Model" VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.7"/>
                <ComboBox Grid.Column="1" Width="200" MinHeight="32"
                          ItemsSource="{Binding Models}"
                          SelectedItem="{Binding SelectedModel}"
                          PlaceholderText="(no models)"/>

                <TextBlock Grid.Column="2" Text="Mode" VerticalAlignment="Center" Margin="16,0,6,0" Opacity="0.7"/>
                <ComboBox Grid.Column="3" Width="150" MinHeight="32"
                          ItemsSource="{Binding Modes}"
                          SelectedItem="{Binding SelectedMode}"
                          ToolTip.Tip="{Binding SelectedMode.Description}"/>

                <TextBox Grid.Column="5" Width="210" Margin="0,0,6,0"
                         Text="{Binding OllamaBaseUrl}"
                         PlaceholderText="http://localhost:11434"
                         ToolTip.Tip="Ollama server URL"/>
                <Button Grid.Column="6" Content="Connect" Command="{Binding RefreshCommand}" Margin="0,0,6,0"/>
                <Button Grid.Column="7" Content="Clear" Command="{Binding ClearChatCommand}"/>
            </Grid>
        </Border>

        <!-- Transcript -->
        <ScrollViewer Grid.Row="1" x:Name="TranscriptScroll" Padding="6">
            <ItemsControl ItemsSource="{Binding Messages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:MessageViewModel">
                        <Border Classes="bubble" Classes.user="{Binding IsUser}">
                            <StackPanel>
                                <TextBlock Text="{Binding Header}" FontSize="11" Opacity="0.6" Margin="0,0,0,2"/>
                                <SelectableTextBlock Text="{Binding Text}" TextWrapping="Wrap"/>

                                <!-- Sources (web search / deep research) -->
                                <Expander Margin="0,8,0,0" IsVisible="{Binding HasSources}"
                                          Header="Sources">
                                    <ItemsControl ItemsSource="{Binding Sources}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:CompileBindings="False">
                                                <StackPanel Margin="0,4">
                                                    <Button Classes="link"
                                                            Content="{Binding Title}"
                                                            CommandParameter="{Binding Url}"
                                                            Command="{Binding DataContext.OpenUrlCommand,
                                                                       RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                    <TextBlock Text="{Binding Url}" FontSize="11" Opacity="0.55"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status / progress bar -->
        <Border Grid.Row="2" Padding="12,6" Background="#11808080" IsVisible="{Binding IsBusy}">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <ProgressBar IsIndeterminate="True" Width="120" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Opacity="0.8"/>
            </StackPanel>
        </Border>

        <!-- Connection status line -->
        <TextBlock Grid.Row="2" Text="{Binding ConnectionStatus}" IsVisible="{Binding !IsBusy}"
                   Margin="12,4" FontSize="12" Opacity="0.6" VerticalAlignment="Center"/>

        <!-- Input -->
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" Margin="8" >
            <TextBox Grid.Column="0" x:Name="InputBox"
                     Text="{Binding InputText}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MaxHeight="160"
                     PlaceholderText="Type a message…  (Enter to send, Shift+Enter for a new line)"/>
            <Button Grid.Column="1" Content="Send" Margin="6,0,0,0" MinWidth="80"
                    Classes="accent"
                    Command="{Binding SendCommand}"
                    IsVisible="{Binding !IsBusy}"/>
            <Button Grid.Column="2" Content="Stop" Margin="6,0,0,0" MinWidth="80"
                    Command="{Binding StopCommand}"
                    IsVisible="{Binding IsBusy}"/>
        </Grid>
    </Grid>

</Window>
