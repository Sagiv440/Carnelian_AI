<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="200"
        x:Class="AI_Interface.Views.DocFormatWindow"
        Width="420" SizeToContent="Height"
        MinWidth="360"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="Save to document">

    <Border Classes="card" CornerRadius="4" Margin="16" Padding="22">
        <StackPanel Spacing="6">
            <TextBlock Classes="brand" Text="Save to document"/>
            <TextBlock TextWrapping="Wrap" Margin="0,4,0,0"
                       Foreground="{DynamicResource AppTextPrimary}" FontSize="14"
                       Text="Choose a format for the saved reply."/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Spacing="10" Margin="0,18,0,0">
                <Button Classes="ghost" Content="Cancel" MinWidth="90" Click="OnCancel"/>
                <Button Classes="ghost" Content="📄 Word (.docx)" MinWidth="120" Click="OnDocx"/>
                <Button Classes="cta" Content="📕 PDF (.pdf)" MinWidth="120" Click="OnPdf"/>
            </StackPanel>
        </StackPanel>
    </Border>

</Window>
