<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AI_Interface.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="440"
        x:Class="AI_Interface.Views.ClarifyWindow"
        x:DataType="vm:ClarifyViewModel"
        Width="480" SizeToContent="Height"
        MinWidth="400" MaxHeight="680"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource AppWindowBackground}"
        Title="A quick question">

    <Design.DataContext>
        <vm:ClarifyViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <!-- Checkbox rows: consistent vertical rhythm + room for wrapped option text. -->
        <Style Selector="CheckBox">
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Styles>

    <Border Classes="card" CornerRadius="5" Margin="14" Padding="20">
        <StackPanel Spacing="14">

            <TextBlock Classes="navheader" Text="THE AGENT ASKS"/>

            <!-- One question, or a tab per question when the agent is undecided about several subjects. -->
            <TabControl ItemsSource="{Binding Questions}" Padding="0">
                <TabControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ClarifyQuestionViewModel">
                        <TextBlock Text="{Binding Header}"/>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate x:DataType="vm:ClarifyQuestionViewModel">
                        <StackPanel Spacing="12" Margin="0,10,0,0">
                            <TextBlock Text="{Binding Question}" TextWrapping="Wrap"
                                       FontSize="15" LineHeight="21"
                                       Foreground="{DynamicResource AppTextPrimary}"/>

                            <ScrollViewer MaxHeight="300" HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="2">
                                    <ItemsControl ItemsSource="{Binding Options}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><StackPanel Spacing="2"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ClarifyOptionViewModel">
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Padding="8,5,0,5">
                                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Other: checkbox + the free-text box it reveals, grouped together -->
                                    <StackPanel Spacing="6" Margin="0,2,0,0">
                                        <CheckBox IsChecked="{Binding OtherSelected, Mode=TwoWay}"
                                                  Padding="8,5,0,5" Content="Other…"/>
                                        <TextBox IsVisible="{Binding OtherSelected}" Margin="29,0,0,2"
                                                 Text="{Binding OtherText, Mode=TwoWay}"
                                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="58"
                                                 PlaceholderText="Type your answer…"/>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Classes="ghost" Content="Cancel" MinWidth="96" Click="OnCancel"/>
                <Button Classes="cta" Content="Send" MinWidth="110"
                        IsEnabled="{Binding CanSubmit}" Click="OnSubmit"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
