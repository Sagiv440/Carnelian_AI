<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ====================================================================
         App-wide control styling for the flat "IDE" look (VS Code / Photoshop):
         system type, sharp corners, hairline borders, solid red-orange accent.
         ==================================================================== -->

    <!-- Window: app font (user-selectable) + flat neutral background. Font family/size use
         DynamicResource so the Theme settings can change them live. -->
    <Style Selector="Window">
        <Setter Property="FontFamily" Value="{DynamicResource AppFont}"/>
        <Setter Property="FontSize" Value="{DynamicResource AppFontSize}"/>
        <Setter Property="Background" Value="{DynamicResource AppWindowBackground}"/>
    </Style>

    <!-- Line height driven by the AppLineHeight token (fontSize × lineSpacing multiplier).
         Scoped to SelectableTextBlock only (used exclusively in the chat transcript for prose,
         list items, and code). Plain TextBlock is left at the default NaN so labels, nav
         buttons, and fixed-size UI text are never clipped by a smaller computed line height. -->
    <Style Selector="SelectableTextBlock">
        <Setter Property="LineHeight" Value="{DynamicResource AppLineHeight}"/>
    </Style>

    <!-- Sharp inputs -->
    <Style Selector="TextBox">
        <Setter Property="CornerRadius" Value="3"/>
    </Style>
    <Style Selector="ComboBox">
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="MinHeight" Value="30"/>
    </Style>
    <Style Selector="NumericUpDown">
        <Setter Property="CornerRadius" Value="3"/>
    </Style>

    <!-- Default buttons: square-ish, compact -->
    <Style Selector="Button">
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Padding" Value="11,5"/>
    </Style>

    <!-- Ghost / toolbar buttons: subtle until hovered -->
    <Style Selector="Button.ghost /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppSurfaceBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#18FFFFFF"/>
    </Style>

    <!-- CTA button: flat solid red-orange accent (VS Code primary-button style) -->
    <Style Selector="Button.cta">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>
    <Style Selector="Button.cta /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AppAccentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.cta:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AppAccentBrush}"/>
    </Style>
    <Style Selector="Button.cta:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AppAccentBrush}"/>
    </Style>
    <Style Selector="Button.cta:pointerover">
        <Setter Property="Opacity" Value="0.88"/>
    </Style>
    <Style Selector="Button.cta:pressed">
        <Setter Property="Opacity" Value="0.78"/>
    </Style>

    <!-- Flat surface panel (sidebar / composer / dialogs) -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppSurfaceBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
    </Style>

    <!-- Section / muted text helpers -->
    <Style Selector="TextBlock.brand">
        <Setter Property="FontFamily" Value="{DynamicResource AppFont}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
    </Style>
    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- ====================================================================
         Left-rail navigation entries (sidebar chat log, Settings categories).
         Promoted from MainWindow so both windows share the look. Full-width,
         left-aligned, sharp; the .active class tints with a translucent accent.
         ==================================================================== -->
    <Style Selector="Button.nav">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Margin" Value="0,1"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}"/>
    </Style>
    <Style Selector="Button.nav /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.nav:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
    </Style>
    <Style Selector="Button.nav.active">
        <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button.nav.active /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#33F2542D"/>
    </Style>

    <!-- Group header above a set of nav entries (e.g. "EDITOR FEATURES") -->
    <Style Selector="TextBlock.navheader">
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="10,14,0,4"/>
    </Style>

</Styles>
