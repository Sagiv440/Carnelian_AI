<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ====================================================================
         App-wide control styling for the sagiv-reuben look:
         Poppins type, generous rounding, glassy surfaces, gradient CTA.
         ==================================================================== -->

    <!-- Window: app font (user-selectable) + deep-navy gradient background. Font family/size use
         DynamicResource so the Theme settings can change them live. -->
    <Style Selector="Window">
        <Setter Property="FontFamily" Value="{DynamicResource AppFont}"/>
        <Setter Property="FontSize" Value="{DynamicResource AppFontSize}"/>
        <Setter Property="Background" Value="{DynamicResource AppWindowBackground}"/>
    </Style>

    <!-- Rounded inputs -->
    <Style Selector="TextBox">
        <Setter Property="CornerRadius" Value="10"/>
    </Style>
    <Style Selector="ComboBox">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="MinHeight" Value="34"/>
    </Style>
    <Style Selector="NumericUpDown">
        <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <!-- Default buttons: rounded, medium weight -->
    <Style Selector="Button">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="14,8"/>
    </Style>

    <!-- Ghost / toolbar buttons: subtle until hovered -->
    <Style Selector="Button.ghost /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppSurfaceBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- CTA button: the signature teal→violet gradient -->
    <Style Selector="Button.cta">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="CornerRadius" Value="12"/>
    </Style>
    <Style Selector="Button.cta /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentGradientBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.cta:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentGradientBrush}"/>
    </Style>
    <Style Selector="Button.cta:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentGradientBrush}"/>
    </Style>
    <Style Selector="Button.cta:pointerover">
        <Setter Property="Opacity" Value="0.92"/>
    </Style>

    <!-- Glassy surface card -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AppSurfaceBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="16"/>
    </Style>

    <!-- Section / muted text helpers -->
    <Style Selector="TextBlock.brand">
        <Setter Property="FontFamily" Value="{DynamicResource AppFont}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentGradientBrush}"/>
    </Style>
    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

</Styles>
