<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AI_Interface.App"
             xmlns:local="using:AI_Interface"
             xmlns:sys="using:System"
             RequestedThemeVariant="Default">
             <!-- "Default" follows the system; ThemeService overrides this from saved settings. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <!-- ============================================================================
         Design tokens — flat "IDE" look (Visual Studio Code / Photoshop):
         system type · neutral dark-gray surfaces · red-orange accent · sharp corners.
         Themeable keys (AppAccentBrush / UserBubbleBrush / AssistantBubbleBrush) are
         overridden at runtime by ThemeService; structural tokens adapt per light/dark.
         ============================================================================ -->
    <Application.Resources>
        <ResourceDictionary>
            <!-- System UI font (overridden at runtime by ThemeService from saved settings) -->
            <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
            <!-- Base font size; overridden at runtime by ThemeService from saved settings. -->
            <sys:Double x:Key="AppFontSize">13</sys:Double>

            <!-- Accent (variant-independent; AppAccentBrush is user-themeable) — red-orange -->
            <SolidColorBrush x:Key="AppAccentBrush" Color="#F2542D"/>
            <SolidColorBrush x:Key="UserBubbleBrush" Color="#2EF2542D"/>
            <SolidColorBrush x:Key="AssistantBubbleBrush" Color="#22888888"/>

            <!-- Near-flat red-orange gradient, kept for compatibility (CTA/brand now use solids) -->
            <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Offset="0" Color="#FF6A45"/>
                <GradientStop Offset="1" Color="#F2542D"/>
            </LinearGradientBrush>

            <ResourceDictionary.ThemeDictionaries>

                <!-- DARK (VS Code / Photoshop neutral gray) — the default -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppWindowBackground" Color="#1E1E1E"/>
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#252526"/>
                    <SolidColorBrush x:Key="AppSurfaceBorderBrush" Color="#3C3C3C"/>
                    <SolidColorBrush x:Key="AppInputBackground" Color="#3C3C3C"/>
                    <SolidColorBrush x:Key="AppTextPrimary" Color="#D4D4D4"/>
                    <SolidColorBrush x:Key="AppTextSecondary" Color="#858585"/>
                    <SolidColorBrush x:Key="AppSuccessBrush" Color="#3FB950"/>
                </ResourceDictionary>

                <!-- LIGHT -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppWindowBackground" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#F3F3F3"/>
                    <SolidColorBrush x:Key="AppSurfaceBorderBrush" Color="#D0D0D0"/>
                    <SolidColorBrush x:Key="AppInputBackground" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="AppTextPrimary" Color="#1F1F1F"/>
                    <SolidColorBrush x:Key="AppTextSecondary" Color="#6E6E6E"/>
                    <SolidColorBrush x:Key="AppSuccessBrush" Color="#2DA44E"/>
                </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://AI_Interface/Styles/ControlStyles.axaml"/>
    </Application.Styles>
</Application>
